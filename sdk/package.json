{
  "name": "@shieldbot/sdk",
  "version": "3.0.0",
  "description": "ShieldBot V3 SDK — agent transaction firewall, threat intelligence, reputation scoring, and prompt injection detection",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "web3",
    "security",
    "firewall",
    "transaction",
    "scanner",
    "honeypot",
    "rug-pull",
    "evm",
    "bsc",
    "ethereum",
    "defi"
  ],
  "license": "MIT",
  "author": "ShieldBot Security",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ridwannurudeen/shieldbot.git",
    "directory": "sdk"
  },
  "homepage": "https://shieldbotsecurity.online",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
