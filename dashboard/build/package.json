    "build": "tailwindcss -i input.css -o tw.css --minify && node assemble.js"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-react": "7.29.7",
    "prop-types": "15.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.12.7",
    "tailwindcss": "3.4.19"
  }
}
