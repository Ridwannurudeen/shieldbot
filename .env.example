# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALERT_CHAT_ID=your_personal_chat_id_here
WEBHOOK_SECRET=your_random_secret_here  # used to authenticate /webhook/uptime calls

# BSC API
BSCSCAN_API_KEY=your_bscscan_api_key_here

# AI Analysis (REQUIRED for AI-powered features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# On-Chain Recording (REQUIRED for recording scans to BSC)
BOT_WALLET_PRIVATE_KEY=your_bot_wallet_private_key_here

# RPC Endpoints
BSC_RPC_URL=https://bsc-dataseed.binance.org/
OPBNB_RPC_URL=https://opbnb-mainnet-rpc.bnbchain.org

# Ethos Network (optional — wallet reputation via Privy)
ETHOS_PRIVY_TOKEN=your_privy_token_here

# CORS — comma-separated allowed origins for the API
# Include your chrome-extension:// ID for production
# CORS — restrict to your actual domains in production (never use * with credentials)
CORS_ALLOW_ORIGINS=https://shieldbotsecurity.online,https://api.shieldbotsecurity.online,http://localhost:5173,http://localhost:3000

# Token Sniffer (bytecode fingerprinting for unverified contracts — register free at tokensniffer.com)
TOKEN_SNIFFER_API_KEY=your_token_sniffer_api_key_here

# Resend (beta welcome emails)
RESEND_API_KEY=your_resend_api_key_here
# RESEND_FROM_EMAIL=ShieldBot <noreply@shieldbotsecurity.online>

# Bot Settings
RISK_THRESHOLD=70
CACHE_DURATION=300
